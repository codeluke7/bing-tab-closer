{
  "manifest_version": 3,
  "name": "Bing Tab Closer",
  "version": "1.0.0",
  "description": "One-click cleanup of all Bing search tabs. Perfect for anyone tired of Bing opening new tabs for every search result.",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_title": "Close All Bing Tabs",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
